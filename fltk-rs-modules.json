{
  "name": "fltk-rs-build-deps",
  "buildsystem": "simple",
  "build-commands": ["true"],
  "sources": [],
  "modules": [
    {
      "name": "gmp",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://ftp.gnu.org/gnu/gmp/gmp-6.3.0.tar.xz",
          "sha256": "a3c2b80201b89e68616f4ad30bc66aee4927c3ce50e33929ca819d5c43538898"
        }
      ],
      "config-opts": [
        "--enable-static",
        "--disable-shared",
        "CFLAGS=-fPIC -std=gnu17"
      ]
    },
    {
      "name": "mpfr",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://ftp.gnu.org/gnu/mpfr/mpfr-4.2.0.tar.xz",
          "sha256": "06a378df13501248c1b2db5aa977a2c8126ae849a9d9b7be2546fb4a9c26d993"
        }
      ],
      "config-opts": [
        "--enable-static",
        "--disable-shared",
        "CFLAGS=-fPIC -std=gnu17"
      ]
    },
    {
      "name": "mpc",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz",
          "sha256": "ab642492f5cf882b74aa0cb730cd410a81edcdbec895183ce930e706c1c759b8"
        }
      ],
      "config-opts": [
        "--enable-static",
        "--disable-shared",
        "CFLAGS=-fPIC -std=gnu17"
      ]
    },
    {
      "name": "libsupc++",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://ftp.gnu.org/gnu/gcc/gcc-15.2.0/gcc-15.2.0.tar.xz",
          "sha256": "438fd996826b0c82485a29da03a72d71d6e3541a83ec702df4271f6fe025d24e"
        }
      ],
      "config-opts": [
        "--enable-static",
        "--disable-shared",
        "--disable-multilib",
        "--enable-languages=c,c++",
        "--disable-bootstrap",
        "--with-mpc=/app",
        "--with-mpfr=/app",
        "--with-gmp=/app",
        "CFLAGS=-fPIC",
        "CXXFLAGS=-fPIC"
      ]
    },
    {
      "name": "libpango-1.0",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/pango/1.56/pango-1.56.3.tar.xz",
          "sha256": "2606252bc25cd8d24e1b7f7e92c3a272b37acd6734347b73b47a482834ba2491"
        }
      ],
      "config-opts": ["-Dxft=enabled", "-Dfreetype=enabled", "-Dcairo=enabled"]
    },
    {
      "name": "pcre",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/PCRE2Project/pcre2/releases/download/pcre2-10.45/pcre2-10.45.tar.gz",
          "sha256": "0e138387df7835d7403b8351e2226c1377da804e0737db0e071b48f07c9d12ee"
        }
      ]
    },
    {
      "name": "harfbuzz",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/harfbuzz/harfbuzz/releases/download/11.2.0/harfbuzz-11.2.0.tar.xz",
          "sha256": "50f7d0a208367e606dbf6eecc5cfbecc01a47be6ee837ae7aff2787e24b09b45"
        }
      ],
      "config-opts": ["-Ddefault_library=static"]
    },
    {
      "name": "cairo",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://www.cairographics.org/releases/cairo-1.18.4.tar.xz",
          "sha256": "445ed8208a6e4823de1226a74ca319d3600e83f6369f99b14265006599c32ccb"
        }
      ],
      "config-opts": ["-Dtests=disabled"]
    },
    {
      "name": "libpanel",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/libpanel.git",
          "tag": "1.8.1"
        }
      ],
      "config-opts": [
        "-Ddocs=disabled",
        "-Dintrospection=disabled",
        "-Dvapi=false"
      ],
      "build-options": {
        "env": ["CFLAGS=-lstdc++", "CXXFLAGS=-ldstdc++"]
      }
    },
    {
      "name": "libdex",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/libdex.git",
          "tag": "0.10.1"
        }
      ],
      "config-opts": [
        "-Ddocs=false",
        "-Dexamples=false",
        "-Dtests=false",
        "-Dsysprof=false"
      ]
    },
    {
      "name": "sysprof",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/sysprof.git",
          "tag": "50.0"
        }
      ],
      "build-options": {
        "env": {
          "PKG_CONFIG_PATH": "/app/lib/pkgconfig:/app/lib64/pkgconfig",
          "CFLAGS": "-I/app/include/libdex-1 -I/app/include/libpanel-1",
          "CXXFLAGS": "-I/app/include/libdex-1 -I/app/include/libpanel-1",
          "LD_LIBRARY_PATH": "/usr/lib/sdk/llvm22/lib:/app/lib64:/app/lib"
        }
      },
      "config-opts": ["-Dsysprofd=none"]
    }
  ]
}
